{
	"name": "strava-next-zero",
	"version": "0.1.0",
	"type": "module",
	"private": true,
	"scripts": {
		"predev": "sleep 3 && open http://localhost:3000 &",
		"dev": "next dev",
		"dev:ui": "next dev",
		"dev:cache": "zero-cache-dev -p ./schema.ts",
		"dev:db-up": "docker compose up",
		"dev:db-down": "docker compose down",
		"dev:clean": "source .env; docker compose down -v; rm -f ${ZERO_REPLICA_FILE}; rm -f ./zero-schema.json",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"build": "next build",
		"start": "next start",
		"lint-format": "biome check --write",
		"schema:generate": "drizzle-zero generate",
		"postinstall": "npm run schema:generate"
	},
	"dependencies": {
		"@auth/drizzle-adapter": "1.11.3",
		"@mapbox/polyline": "1.2.1",
		"@rocicorp/zero": "1.8.0",
		"@tanstack/react-table": "8.21.3",
		"better-auth": "1.6.23",
		"clsx": "2.1.1",
		"dayjs": "1.11.21",
		"dotenv": "17.4.2",
		"drizzle-orm": "0.45.2",
		"drizzle-zero": "0.20.0",
		"leaflet": "1.9.4",
		"next": "16.2.11",
		"pg": "8.22.0",
		"react": "19.2.8",
		"react-dom": "19.2.8",
		"react-leaflet": "5.0.0",
		"strava-v3": "4.0.1",
		"throttled-queue": "3.0.0",
		"tsx": "4.23.1",
		"usehooks-ts": "3.1.1"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.5",
		"@eslint/eslintrc": "3.3.6",
		"@tailwindcss/postcss": "4.3.3",
		"@types/leaflet": "1.9.21",
		"@types/mapbox__polyline": "1.0.5",
		"@types/node": "26.1.1",
		"@types/pg": "8.20.0",
		"@types/react": "19.2.17",
		"@types/react-dom": "19.2.3",
		"babel-plugin-react-compiler": "1.0.0",
		"baseline-browser-mapping": "2.11.0",
		"drizzle-kit": "0.31.10",
		"eslint": "10.7.0",
		"eslint-config-next": "16.2.11",
		"postcss": "8.5.21",
		"tailwindcss": "4.3.3",
		"typescript": "7.0.2",
		"zod": "4.4.3"
	},
	"overrides": {
		"@types/react": "19.2.17",
		"@types/react-dom": "19.2.3"
	}
}
